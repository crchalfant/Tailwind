# Tailwind — Environment Variables
# Copy this file to .env.local and fill in your API keys.

# Sector performance data is sourced from Yahoo Finance (no API key required)

# Marketaux API key — used for industry news with sentiment scores
# Get yours free at: https://marketaux.com/register
MARKETAUX_API_KEY=your_marketaux_api_key_here

# Anthropic API key — used for the AI briefing (Claude)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: base path for sub-path deployment (e.g. /tools/tailwind)
# Leave empty for root deployment (default for Vercel)
NEXT_PUBLIC_BASE_PATH=
